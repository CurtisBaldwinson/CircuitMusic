---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// ── Parse CSV files at build time ──────────────────────────────────
const publicDir = path.resolve('public');

function parseCsv(filePath: string): Record<string, string>[] {
  const raw = fs.readFileSync(filePath, 'utf-8').trim();
  const lines = raw.split('\n');
  const headers = lines[0].split(',');
  return lines.slice(1).filter(Boolean).map(line => {
    // Handle quoted fields containing commas
    const values: string[] = [];
    let current = '';
    let inQuotes = false;
    for (const char of line) {
      if (char === '"') { inQuotes = !inQuotes; continue; }
      if (char === ',' && !inQuotes) { values.push(current); current = ''; continue; }
      current += char;
    }
    values.push(current);
    return Object.fromEntries(headers.map((h, i) => [h, values[i] ?? '']));
  });
}

const genreRows = parseCsv(path.join(publicDir, 'results_genre_averages.csv'));
const trackRows = parseCsv(path.join(publicDir, 'results_per_track.csv'));

// Genre display order & colors
const GENRE_ORDER = ['Circuit', 'Tribal House', 'Disco', 'House', 'Jazz'];
const GENRE_COLORS: Record<string, string> = {
  Circuit: '#c084fc',
  'Tribal House': '#f97316',
  Disco: '#facc15',
  House: '#4ade80',
  Jazz: '#38bdf8',
};

// Sort genre rows to match display order
const sortedGenres = GENRE_ORDER
  .map(name => genreRows.find(r => r.genre === name))
  .filter((r): r is Record<string, string> => r !== undefined);

// Build the data payload for the client-side JS
const genreNames = sortedGenres.map(r => r.genre);
const colors = genreNames.map(g => GENRE_COLORS[g]);

function gf(row: Record<string, string>, key: string): number {
  return parseFloat(row[key]);
}

// The METRICS object that script.js will consume
const metricsPayload = {
  bpm: {
    title: "Tempo (BPM)",
    explain: "Beats per minute measured by librosa's beat tracker. Circuit music's 128-130 BPM range is faster than classic disco and standard house, placing it firmly in peak-time electronic territory.",
    values: sortedGenres.map(r => gf(r, 'bpm_mean')),
    unit: 'BPM', min: 80, max: 160,
  },
  tresillo: {
    title: "Tresillo Index",
    explain: "Measures how strongly the 3+3+2 tresillo pattern appears in the kick/bass layer. A score above 1.0 means the tresillo positions receive more energy than non-tresillo positions.",
    values: sortedGenres.map(r => gf(r, 'tresillo_lf_ratio_mean')),
    unit: '', min: 0.8, max: 1.5,
    refLine: { value: 1.0, label: 'Baseline (no preference)' },
  },
  density: {
    title: "Event Density (onsets/sec)",
    explain: "Number of musical events (note attacks, percussion hits) per second. Higher density indicates a busier, more layered production.",
    values: sortedGenres.map(r => gf(r, 'events_per_sec_mean')),
    unit: '/sec', min: 0, max: 10,
  },
  percussive: {
    title: "Percussive Energy %",
    explain: "What percentage of total audio energy is percussive vs. harmonic, measured via HPSS (Harmonic-Percussive Source Separation).",
    values: sortedGenres.map(r => gf(r, 'percussive_pct_mean')),
    unit: '%', min: 0, max: 65,
  },
  harmonic: {
    title: "Harmonic Diversity (Chroma Entropy)",
    explain: "Shannon entropy of the chroma distribution &mdash; how many different pitch classes are used and how evenly. Higher entropy means more tonal complexity.",
    values: sortedGenres.map(r => gf(r, 'spectral_entropy_mean')),
    unit: ' bits', min: 3.5, max: 7,
  },
  dynamic: {
    title: "Dynamic Range (RMS CoV)",
    explain: "Coefficient of variation of the RMS energy &mdash; how much loudness varies throughout the segment. Higher values indicate greater dynamic contrast.",
    values: sortedGenres.map(r => gf(r, 'dynamic_range_mean')),
    unit: '', min: 0, max: 1.0,
  },
};

// Radar chart raw data for normalization on the client
const radarPayload = Object.fromEntries(
  sortedGenres.map(r => [
    r.genre,
    [
      gf(r, 'bpm_mean'),
      gf(r, 'beat_cv_mean'),
      gf(r, 'tresillo_lf_ratio_mean'),
      gf(r, 'events_per_sec_mean'),
      gf(r, 'percussive_pct_mean'),
      gf(r, 'spectral_entropy_mean'),
    ],
  ])
);

// Table column definitions: [header, csvKey, format, isHighest?]
interface TableCol {
  header: string;
  headerNote?: string;
  key: string;
  fmt: (v: number) => string;
}

const tableCols: TableCol[] = [
  { header: 'BPM', key: 'bpm_mean', fmt: (v) => v.toFixed(1) },
  { header: 'Beat Regularity', headerNote: '(lower = rigid)', key: 'beat_cv_mean', fmt: (v) => v.toFixed(3) },
  { header: 'Tresillo Index', key: 'tresillo_lf_ratio_mean', fmt: (v) => v.toFixed(2) },
  { header: 'Events/sec', key: 'events_per_sec_mean', fmt: (v) => v.toFixed(2) },
  { header: 'Percussive %', key: 'percussive_pct_mean', fmt: (v) => v.toFixed(1) + '%' },
  { header: 'Harmonic Entropy', key: 'spectral_entropy_mean', fmt: (v) => v.toFixed(2) },
  { header: 'Dynamic Range', key: 'dynamic_range_mean', fmt: (v) => v.toFixed(3) },
];

// Find the most notable value per column for bolding
function findNotableIdx(col: TableCol): number {
  const vals = sortedGenres.map(r => gf(r, col.key));
  // Beat regularity: lowest is most notable; others: highest
  if (col.key === 'beat_cv_mean') {
    return vals.indexOf(Math.min(...vals));
  }
  return vals.indexOf(Math.max(...vals));
}

// Total track count across all genres
const totalTracks = sortedGenres.reduce((sum, r) => sum + parseInt(r.n_tracks, 10), 0);

// Build the full client-side data payload
const clientData = {
  genres: genreNames,
  colors,
  metrics: metricsPayload,
  radar: radarPayload,
  totalTracks,
};
---

<Layout
  title="Circuit Music: A Genre Defined"
  description="An objective, data-driven exploration of circuit music: its rhythm, structure, history, and measurable differences from disco, house, jazz, and tribal music."
>

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="#" class="nav-logo" aria-label="Circuit Music home">
      <img src="/circuitmusic-logo.png" alt="" class="nav-logo-img" width="32" height="32" />
      <span>Circuit Music</span>
    </a>
    <ul class="nav-links" role="list">
      <li><a href="#definition">Definition</a></li>
      <li><a href="#rhythm">Rhythm</a></li>
      <li><a href="#data">Data</a></li>
      <li><a href="#djs">DJs</a></li>
      <li><a href="#subjective">Character</a></li>
      <li><a href="/blog">Blog</a></li>
    </ul>
    <button class="nav-theme" data-theme-toggle aria-label="Switch to light mode">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </nav>

  <!-- HERO -->
  <header class="hero" role="banner">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-grid"></div>
      <div class="hero-glow hero-glow-1"></div>
      <div class="hero-glow hero-glow-2"></div>
      <canvas class="hero-waveform" id="heroWave" aria-hidden="true"></canvas>
    </div>
    <div class="hero-content">
      <p class="hero-eyebrow">A Musicological Analysis</p>
      <div class="hero-lockup">
        <h1 class="hero-title">Circuit<br/><em>Music</em></h1>
        <div class="hero-logo-wrap" aria-hidden="true">
          <img src="/circuitmusic-logo.png" alt="" class="hero-logo" width="220" height="220" />
          <div class="flame-particles">
            <span class="flame f1"></span>
            <span class="flame f2"></span>
            <span class="flame f3"></span>
            <span class="flame f4"></span>
            <span class="flame f5"></span>
            <span class="flame f6"></span>
            <span class="flame f7"></span>
            <span class="flame f8"></span>
          </div>
        </div>
      </div>
      <p class="hero-sub">From Fire Island to global stages, the genre built on tresillo, tribalism, and relentless forward motion. Defined objectively, measured programmatically.</p>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value"><span data-count="129">0</span><span class="stat-unit">BPM</span></span>
          <span class="stat-label">Core Tempo</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value" data-count="1977">0</span>
          <span class="stat-label">Fire Island Origins</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value" data-count={sortedGenres.length}>0</span>
          <span class="stat-label">Genres Compared</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll" aria-hidden="true">
      <div class="hero-scroll-line"></div>
    </div>
  </header>

  <div class="mobile-blog-banner">
    <a href="/blog" class="mobile-blog-banner-link">
      <span class="mobile-blog-banner-badge">New</span>
      <span class="mobile-blog-banner-text">Read the blog &rarr;</span>
    </a>
  </div>

  <main>

    <!-- SECTION: DEFINITION -->
    <section class="section" id="definition">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">01 / What It Is</span>
          <h2>Circuit is a Genre</h2>
        </div>
        <div class="two-col">
          <div class="prose">
            <p>Circuit music emerged from the gay club underground of the late 1970s, specifically the afternoon Tea Dances of New York's Fire Island and marathon events at venues like <strong>The Saint</strong> in the East Village and San Francisco's <strong>Trocadero Transfer</strong>.<sup class="cite"><a href="https://www.advocate.com/news/history-of-lgbtq-circuit-parties" target="_blank" rel="noopener" title="The Advocate: History of LGBTQ Circuit Parties">2</a></sup> It is as much a genre as disco, which also emerged from a specific subculture and specific venues.</p>
            <p>The genre is defined by a consistent and measurable set of sonic characteristics: a tresillo-over-two bass and kick pattern at 128-130 BPM, high percussive density layered against a lush harmonic foundation, and a production maximalism that distinguishes it from standard house music.</p>
            <p>The claim that "circuit is just a context, not a genre" misunderstands genre formation itself.<sup class="cite"><a href="https://www.thefader.com/2015/06/10/tresillo-club-music" target="_blank" rel="noopener" title="The FADER: How Tresillo Conquered Club Music">3</a></sup> Disco, jazz, and blues all emerged from specific social contexts. The sonic fingerprint is what defines a genre, and circuit music has one.</p>
          </div>
          <div class="timeline">
            <div class="timeline-item">
              <span class="timeline-year">1970s</span>
              <div class="timeline-content">
                <strong>Tea Dances & The Saint</strong>
                <p>Marathon disco parties in NYC and SF. Gay liberation culture fuses with dance music.</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">1989</span>
              <div class="timeline-content">
                <strong>Junior Vasquez at Sound Factory</strong>
                <p>12-hour sets define the tribal-house arc. Beat-driven, percussive, relentless.</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">1990s</span>
              <div class="timeline-content">
                <strong>Global Circuit Parties</strong>
                <p>White Party, Black & Blue, Winter Party. The circuit becomes a worldwide network with its own music ecosystem.</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2000s</span>
              <div class="timeline-content">
                <strong>Progressive & Electro Influence</strong>
                <p>Peter Rauhofer, Offer Nissim. Lush synths and Middle Eastern scales enter the palette.</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">Now</span>
              <div class="timeline-content">
                <strong>Global Flavors</strong>
                <p>Brazilian samba percussion, Latin aleteo, Israeli progressive circuit. One rhythm, many voices.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION: RHYTHM -->
    <section class="section section-dark" id="rhythm">
      <div class="container">

        <!-- ACT 1: THE HYPOTHESIS -->
        <div class="act-block">
          <div class="section-header">
            <span class="section-tag">02 / The Core Pattern</span>
            <span class="act-label">Act I &mdash; The Hypothesis</span>
            <h2>The Tresillo</h2>
          </div>
          <p class="section-intro">Every genre has a rhythmic fingerprint. Circuit's first and most obvious candidate is the tresillo: a 3+3+2 subdivision of 8 sixteenth notes, inherited from Sub-Saharan Africa through Afro-Cuban music,<sup class="cite"><a href="https://en.wikipedia.org/wiki/Tresillo_(rhythm)" target="_blank" rel="noopener" title="Wikipedia: Tresillo (rhythm)">1</a></sup> carried through New Orleans into contemporary club music. Any serious listener of circuit will tell you the beat has a forward-rolling, almost suspended quality. The tresillo, in principle, explains that feeling. Now it's measured.</p>

          <div class="rhythm-header">
            <div class="rhythm-audio-btn-wrap">
              <button class="rhythm-play-btn" id="rhythmPlayBtn" aria-label="Play circuit music sample" aria-pressed="false">
                <span class="rpb-icon rpb-icon-play" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                </span>
                <span class="rpb-icon rpb-icon-stop" aria-hidden="true" style="display:none">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2"/></svg>
                </span>
                <span class="rpb-label">Hear it</span>
              </button>
              <span class="rhythm-audio-note">8-sec clip, Ben Bakson @ Xlsior Mykonos 2022</span>
            </div>
          </div>

          <div class="rhythm-visual" aria-label="Tresillo rhythm pattern visualization">
            <div class="rhythm-label">Tresillo Bass (3+3+2)</div>
            <div class="rhythm-grid" id="tresilloGrid"><!-- Generated by JS --></div>
            <div class="rhythm-label">Four-on-the-Floor Kick</div>
            <div class="rhythm-grid" id="kickGrid"></div>
            <div class="rhythm-label">Combined &mdash; Circuit Tension</div>
            <div class="rhythm-grid" id="combinedGrid"></div>
            <div class="rhythm-key">
              <span class="key-hit">■ Hit</span>
              <span class="key-rest">□ Rest</span>
            </div>
          </div>

          <div class="rhythm-explanation">
            <div class="rhythm-card">
              <div class="rhythm-card-icon">3+3+2</div>
              <h3>Tresillo Pattern</h3>
              <p>Three attacks in 8 sixteenth-note slots: positions 1, 4, and 7. Creates a forward lean, arriving early relative to the grid.</p>
            </div>
            <div class="rhythm-card">
              <div class="rhythm-card-icon">4/4</div>
              <h3>House Foundation</h3>
              <p>The four-on-the-floor kick grounds the listener in regular 4/4 meter, providing the anchor that makes the tresillo's tension readable.</p>
            </div>
            <div class="rhythm-card">
              <div class="rhythm-card-icon">⟳</div>
              <h3>Polyrhythmic Tension</h3>
              <p>Layering tresillo against a 4/4 framework creates a polyrhythm: two competing metric frameworks that the brain resolves as groove.</p>
            </div>
          </div>

          <div class="tresillo-lineage">
            <h3>Lineage</h3>
            <div class="lineage-flow">
              <span class="lineage-node">Sub-Saharan Africa</span>
              <span class="lineage-arrow">→</span>
              <span class="lineage-node">Afro-Cuban / Habanera</span>
              <span class="lineage-arrow">→</span>
              <span class="lineage-node">New Orleans Second Line</span>
              <span class="lineage-arrow">→</span>
              <span class="lineage-node">Reggaeton / Dembow</span>
              <span class="lineage-arrow">→</span>
              <span class="lineage-node accent">Circuit / Tribal House</span>
            </div>
          </div>
        </div>

        <!-- ACT 2: THE COMPLICATION -->
        <div class="act-block act-block-complication">
          <div class="act-label-inline">
            <span class="act-label act-label-amber">Act II &mdash; The Complication</span>
          </div>
          <h3 class="act-heading">The Data Pushed Back</h3>
          <p class="act-body">Even Coldplay uses <a href="https://www.youtube.com/watch?v=sMPt9BQTFXw" target="_blank" rel="noopener">tresillo</a>, so that can't be the only characteristic that defines the sound. Measuring the tresillo index across five genres produced a surprise: the numbers were closer than expected. Circuit scored {gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'tresillo_index_mean').toFixed(2)}, tribal house {gf(sortedGenres.find(r => r.genre === 'Tribal House')!, 'tresillo_index_mean').toFixed(2)}, house {gf(sortedGenres.find(r => r.genre === 'House')!, 'tresillo_index_mean').toFixed(2)}. No clean separation. The reason turns out to be structural: in a full stereo mix, the kick drum is dramatically louder than everything above it. When the algorithm sums all onset energy, the four-on-the-floor kick dominates and every genre looks roughly duple. The tresillo, if it is there, is being buried under the one thing all dance music shares.</p>
          <div class="complication-callout">
            <div class="complication-stat">
              <span class="complication-val">{gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'tresillo_index_mean').toFixed(2)}</span>
              <span class="complication-genre">Circuit</span>
            </div>
            <div class="complication-divider">vs.</div>
            <div class="complication-stat">
              <span class="complication-val">{gf(sortedGenres.find(r => r.genre === 'House')!, 'tresillo_index_mean').toFixed(2)}</span>
              <span class="complication-genre">House</span>
            </div>
            <div class="complication-divider">vs.</div>
            <div class="complication-stat">
              <span class="complication-val">{gf(sortedGenres.find(r => r.genre === 'Tribal House')!, 'tresillo_index_mean').toFixed(2)}</span>
              <span class="complication-genre">Tribal House</span>
            </div>
            <p class="complication-note">Tresillo index ({sortedGenres[0] && sortedGenres.find(r => r.genre === 'Circuit')!.n_tracks} tracks per genre, mean). Closer than the hypothesis predicted.</p>
          </div>
          <p class="act-body">This does not mean the pattern is absent. It means the full-mix measurement is too coarse a tool to recover it. The kick drum's dominance in a stereo dance mix is not a methodological failure, it is a fact about how this music is engineered. A finer instrument was needed.</p>
        </div>

        <!-- ACT 3: THE REFINED FINDING -->
        <div class="act-block act-block-finding">
          <div class="act-label-inline">
            <span class="act-label act-label-teal">Act III &mdash; The Refined Finding</span>
          </div>
          <h3 class="act-heading">Subdivision Pressure</h3>
          <p class="act-body">A second analysis isolated the hi-frequency percussion layer:the band above 2,000 Hz where hi-hats, synth stabs, shakers, and rides live. The kick drum barely registers there. Then, instead of testing named templates, the energy was measured across all 16 sixteenth-note positions per two bars, grouped into three levels: quarter-note beats (1, 2, 3, 4), eighth-note positions (the "and" between beats), and sixteenth-note positions (the "e" and "ah" in between). The result was unambiguous.</p>

          <div class="subdivision-chart-wrap">
            <div class="subdivision-chart-header">
              <h4>Hi-Perc Energy by Subdivision Level</h4>
              <p class="subdivision-chart-sub">Fraction of hi-frequency percussion energy falling on each rhythmic subdivision, averaged across 3 tracks per genre. 120-second segments, 2-bar sixteenth-note grid.</p>
            </div>
            <div class="subdivision-bars" id="subdivisionBars" aria-label="Subdivision energy chart"></div>
            <div class="subdivision-legend">
              <span class="subdiv-key subdiv-key-q">Quarter (1 2 3 4)</span>
              <span class="subdiv-key subdiv-key-e">Eighth (+)</span>
              <span class="subdiv-key subdiv-key-s">Sixteenth (e, ah)</span>
            </div>
          </div>


          <p class="act-body">Circuit and tribal house place two to three times as much hi-frequency percussion energy into the sixteenth-note positions as house or disco do. That energy is not random noise: across 120-second segments, the patterns repeat with measurable consistency. The groove is defined not by one named cell, but by persistent occupation of the sub-beat space above the kick.</p>
        </div>

        <!-- ACT 4: THE HUMAN CONCLUSION -->
        <div class="act-block act-block-conclusion">
          <div class="act-label-inline">
            <span class="act-label act-label-violet">Act IV &mdash; The Conclusion</span>
          </div>
          <h3 class="act-heading">A Groove Grammar, Not a Single Cell</h3>
          <p class="act-body">What the data supports is not "circuit equals tresillo." The tresillo is a real and meaningful antecedent, with a lineage through Afro-Cuban and New Orleans music into tribal house and circuit. But the pattern as heard by listeners is better described at a higher level of abstraction.</p>
          <blockquote class="act-pullquote">
            Circuit music tends to preserve a rigid quarter-note floor while shifting much of its expressive rhythmic identity into recurring off-beat subdivisions, producing a groove that feels driving, suspended, and physically insistent rather than merely straight or square.
          </blockquote>
          <p class="act-body">That is closer to what the data supports, and closer to what the body feels. Genre is not only where notes fall. It is also what the placement does over the course of an hour in a dark room.</p>
        </div>

      </div>
    </section>

    <!-- SECTION: DATA -->
    <section class="section" id="data">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">03 / Programmatic Analysis</span>
          <h2>Measured Differences</h2>
        </div>
        <p class="section-intro">{sortedGenres.length} genres were analyzed across {totalTracks} tracks using librosa at 44.1kHz. Each metric below is a direct measurement, not subjective description.</p>

        <!-- Metric selector -->
        <div class="chart-nav" role="tablist" aria-label="Select metric to display">
          <button class="chart-tab active" data-metric="bpm" role="tab" aria-selected="true">Tempo</button>
          <button class="chart-tab" data-metric="tresillo" role="tab" aria-selected="false">Tresillo</button>
          <button class="chart-tab" data-metric="density" role="tab" aria-selected="false">Event Density</button>
          <button class="chart-tab" data-metric="percussive" role="tab" aria-selected="false">Percussion</button>
          <button class="chart-tab" data-metric="harmonic" role="tab" aria-selected="false">Harmonic Richness</button>
          <button class="chart-tab" data-metric="dynamic" role="tab" aria-selected="false">Dynamic Range</button>
        </div>

        <div class="chart-stage">
          <div class="chart-description" id="chartDescription">
            <h3 id="chartTitle">Tempo (BPM)</h3>
            <p id="chartExplain">Beats per minute measured by librosa's beat tracker. Circuit music's 128-130 BPM range is faster than classic disco and standard house, placing it firmly in peak-time electronic territory.</p>
          </div>
          <div class="chart-wrap">
            <canvas id="mainChart" aria-label="Genre comparison chart"></canvas>
          </div>
        </div>

        <!-- Data table (generated from CSV at build time) -->
        <div class="data-table-wrap">
          <h3 class="table-title">Full Analysis Results <span class="th-note">({totalTracks} tracks across {sortedGenres.length} genres)</span></h3>
          <div class="table-scroll">
            <table class="data-table" aria-label="Programmatic analysis results by genre">
              <thead>
                <tr>
                  <th scope="col">Genre</th>
                  {tableCols.map(col => (
                    <th scope="col">{col.header}{col.headerNote && <span class="th-note"> {col.headerNote}</span>}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {sortedGenres.map((row, rowIdx) => {
                  const isCircuit = row.genre === 'Circuit';
                  return (
                    <tr class={isCircuit ? 'row-highlight' : ''}>
                      <td><span class="genre-dot" style={`--c:${GENRE_COLORS[row.genre]}`}></span> {row.genre}</td>
                      {tableCols.map((col, colIdx) => {
                        const val = gf(row, col.key);
                        const notable = findNotableIdx(col) === rowIdx;
                        return <td>{notable ? <strong>{col.fmt(val)}</strong> : col.fmt(val)}</td>;
                      })}
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Insight cards -->
        <div class="insight-grid">
          <div class="insight-card">
            <span class="insight-icon">♩</span>
            <h3>Circuit vs Disco</h3>
            <p>Same four-on-the-floor DNA. But disco is more mechanically rigid (CV {gf(sortedGenres.find(r => r.genre === 'Disco')!, 'beat_cv_mean').toFixed(3)} vs {gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'beat_cv_mean').toFixed(3)}), more percussive ({gf(sortedGenres.find(r => r.genre === 'Disco')!, 'percussive_pct_mean').toFixed(0)}% vs {gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'percussive_pct_mean').toFixed(0)}%), and uses live orchestral instruments against circuit's synthesized maximalism. Circuit is faster and harmonically busier.</p>
          </div>
          <div class="insight-card">
            <span class="insight-icon">⌥</span>
            <h3>Circuit vs House</h3>
            <p>Circuit is house's louder, denser cousin. Higher BPM, more onsets per second ({gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'events_per_sec_mean').toFixed(2)} vs {gf(sortedGenres.find(r => r.genre === 'House')!, 'events_per_sec_mean').toFixed(2)}), brighter spectral centroid ({Math.round(gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'spectral_centroid_hz_mean')).toLocaleString()} Hz vs {Math.round(gf(sortedGenres.find(r => r.genre === 'House')!, 'spectral_centroid_hz_mean')).toLocaleString()} Hz), and more deliberate tresillo layering on top of the shared four-on-the-floor skeleton.</p>
          </div>
          <div class="insight-card">
            <span class="insight-icon">♭</span>
            <h3>Circuit vs Jazz</h3>
            <p>Distant relatives through the tresillo's African lineage. Jazz is {(100 - gf(sortedGenres.find(r => r.genre === 'Jazz')!, 'percussive_pct_mean')).toFixed(0)}% harmonic energy vs circuit's {gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'percussive_pct_mean').toFixed(0)}%, nearly opposite. Jazz has massive dynamic range ({gf(sortedGenres.find(r => r.genre === 'Jazz')!, 'dynamic_range_mean').toFixed(2)}); circuit is compressed for DJ mixing ({gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'dynamic_range_mean').toFixed(2)}). Both share higher-than-baseline tresillo presence.</p>
          </div>
          <div class="insight-card">
            <span class="insight-icon">◉</span>
            <h3>The Tresillo Finding</h3>
            <p>Tribal house scores highest on the tresillo index ({gf(sortedGenres.find(r => r.genre === 'Tribal House')!, 'tresillo_lf_ratio_mean').toFixed(2)}), confirming it as a primary structural design choice. Circuit ({gf(sortedGenres.find(r => r.genre === 'Circuit')!, 'tresillo_lf_ratio_mean').toFixed(2)}) and Disco ({gf(sortedGenres.find(r => r.genre === 'Disco')!, 'tresillo_lf_ratio_mean').toFixed(2)}) cluster at a moderate level. Notably, Jazz ({gf(sortedGenres.find(r => r.genre === 'Jazz')!, 'tresillo_lf_ratio_mean').toFixed(2)}) and House ({gf(sortedGenres.find(r => r.genre === 'House')!, 'tresillo_lf_ratio_mean').toFixed(2)}) score above Circuit -- suggesting tresillo-like rhythmic placement is widespread across genres, but tribal house maximizes it intentionally.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG CTA -->
